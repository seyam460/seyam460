# =============================================
# Main — Run করো
# =============================================
if __name__ == "__main__":
    print("=" * 50)
    print("🎓 CERTIFICATE GENERATOR")
    print("=" * 50)
    print("\n1. Template তৈরি করো")
    print("2. একটি Certificate বানাও")
    print("3. Bulk Certificate বানাও")

    choice = input("\nতোমার choice দাও (1/2/3): ")

    if choice == "1":
        create_certificate_template()

    elif choice == "2":
        name = input("name:seyam ")
        course = input("course:Data Structures ")
